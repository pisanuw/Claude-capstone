# Accessibility Lens environment variables.
# Copy this file to .env and fill in real values. Never commit your real .env.
# The app runs fully WITHOUT any of these set; they only enable extras.

# Port the server listens on. Defaults to 3000.
PORT=3000

# Optional: enable AI-generated, context-aware fix suggestions via Claude.
# If unset or blank, the app falls back to deterministic rule-based fixes and
# works exactly the same, just without the model-written code rewrites.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for fix suggestions.
# Defaults to claude-sonnet-4-20250514.
ANTHROPIC_MODEL=

# Optional: how many of the most severe issues per scan to send to the model.
# Bounds latency and cost. Defaults to 5.
AI_ENRICH_LIMIT=5

# Optional: absolute or relative path to the built client assets to serve.
# Defaults to ../../client/dist (correct for the standard build layout).
CLIENT_DIR=
