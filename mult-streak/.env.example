# mult-streak environment. Copy to .env for local runs. App works with none set
# (the email feature is simply disabled without RESEND_API + ADMIN_EMAIL).
PORT=3000
# Secret used to HMAC-sign the game-state cookie. Set a long random value in prod.
COOKIE_SECRET=
# Minutes of inactivity before a player counts as "stopped" (default 15).
IDLE_MINUTES=15
# Where the small JSON activity file is written (default ./data/activity.json).
ACTIVITY_FILE=
# Email: both required to enable notifications. RESEND_API is the Resend API key.
RESEND_API=
ADMIN_EMAIL=
# From address (domain must be verified in Resend). Defaults to mult-streak@pisan.me
FROM_EMAIL=
