# ─────────────────────────────────────────────────────────────────────────────
# Claude-capstone — Environment Variables (TEMPLATE)
#
# Copy to .env and fill in real values. .env is gitignored.
# Never commit real secrets.
#
# Generation helpers used below:
#   hex32:  python3 -c "import secrets; print(secrets.token_hex(32))"
#   hex24:  python3 -c "import secrets; print(secrets.token_hex(24))"
#   uuid:   python3 -c "import uuid; print(uuid.uuid4())"
# ─────────────────────────────────────────────────────────────────────────────


# ── App identity ──────────────────────────────────────────────────────────────

APP_URL=https://example.com
ADMIN_EMAIL=admin@example.com
# Comma-separated list of admin emails for tools that support multiple admins.
ADMIN_EMAILS=admin@example.com


# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME


# ── Auth: JWT + token encryption ──────────────────────────────────────────────
# Both should be 32-byte hex strings. Generate with hex32 helper above.

JWT_SECRET=REPLACE_ME_HEX32
TOKEN_ENCRYPTION_KEY=REPLACE_ME_HEX32
# Legacy / Flask-style equivalent:
FLASK_SECRET_KEY=REPLACE_ME_HEX32
# NextAuth equivalent if you use it instead of JWT_SECRET:
AUTH_SECRET=REPLACE_ME_HEX32
NEXTAUTH_URL=https://example.com


# ── Email: Resend ─────────────────────────────────────────────────────────────
# Get a key at https://resend.com/api-keys

RESEND_API_KEY=re_REPLACE_ME
# Domain used in the From address of magic-link / notification emails.
AUTH_FROM_EMAIL_DOMAIN=example.com
AUTH_FROM_EMAIL=YourApp <noreply@example.com>
FROM_EMAIL=noreply@example.com

# SMTP route (Resend exposes one — same key as password). Leave HOST empty to disable.
AUTH_SMTP_HOST=smtp.resend.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=resend
AUTH_SMTP_PASS=re_REPLACE_ME
AUTH_SMTP_FROM=noreply@example.com


# ── Google OAuth ──────────────────────────────────────────────────────────────
# Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs.

GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE_ME
# Some stacks (e.g., NextAuth) use these names instead:
AUTH_GOOGLE_ID=REPLACE_ME.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-REPLACE_ME

# Google Custom Search (optional)
GOOGLE_API_KEY=REPLACE_ME
GOOGLE_CX=REPLACE_ME


# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT: github.com/settings/personal-access-tokens

GITHUB_TOKEN=github_pat_REPLACE_ME
GITHUB_USERNAME=your-handle


# ── Deploy: Netlify / Render ──────────────────────────────────────────────────
# Netlify: app.netlify.com/user/applications#personal-access-tokens
# Render:  dashboard.render.com → Account Settings → API Keys

NETLIFY_AUTH_TOKEN=REPLACE_ME
RENDER_API_KEY=rnd_REPLACE_ME


# ── Database: Neon (Postgres) ─────────────────────────────────────────────────
# neon.tech → project → Connection Details. URL-encode special chars in passwords.

DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require


# ── Database / BaaS: Supabase ─────────────────────────────────────────────────
# supabase.com → Project Settings → API + Database.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_STORAGE_BUCKET=your-bucket-name
# Frontend-exposed (Vite):
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME


# ── Cache / queue: Upstash (Redis) ────────────────────────────────────────────
# console.upstash.com → database → REST API.

UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME


# ── Observability: Sentry ─────────────────────────────────────────────────────
# sentry.io → Settings → Projects → Client Keys (DSN) + Auth Tokens.

SENTRY_DSN=https://REPLACE_ME@oXXXX.ingest.sentry.io/XXXX
SENTRY_AUTH_TOKEN=sntrys_REPLACE_ME
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug


# ── Product analytics: PostHog ────────────────────────────────────────────────
# app.posthog.com → Project Settings → Project API Key.

POSTHOG_API_KEY=phc_REPLACE_ME
POSTHOG_HOST=https://us.i.posthog.com
# Frontend-exposed equivalents:
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ── Edge / DNS: Cloudflare ────────────────────────────────────────────────────
# dash.cloudflare.com → My Profile → API Tokens.

CLOUDFLARE_ACCOUNT_ID=REPLACE_ME
CLOUDFLARE_API_TOKEN=REPLACE_ME


# ── Project tracking: Linear ──────────────────────────────────────────────────
# linear.app → Settings → API → Personal API keys.

LINEAR_API_KEY=lin_api_REPLACE_ME


# ── Mobile builds: Expo EAS ───────────────────────────────────────────────────
# expo.dev → Account Settings → Access Tokens.

EXPO_TOKEN=REPLACE_ME
EAS_PROJECT_ID=REPLACE_ME


# ── Sandboxed code execution: E2B ─────────────────────────────────────────────
# e2b.dev/dashboard

E2B_API_KEY=e2b_REPLACE_ME


# ── Discord bot (optional) ────────────────────────────────────────────────────
# discord.com/developers/applications

DISCORD_TOKEN=REPLACE_ME
DISCORD_CLIENT_ID=REPLACE_ME


# ── Cron / scheduled functions ────────────────────────────────────────────────

CRON_SECRET=REPLACE_ME_HEX32
SUPERADMIN_SECRET=REPLACE_ME_HEX24


# ── Frontend (Vite-prefixed; safe to expose to the browser) ───────────────────

VITE_API_URL=https://api.example.com
VITE_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
NEXT_PUBLIC_APP_URL=https://example.com


# ── Build / runtime ───────────────────────────────────────────────────────────

NODE_VERSION=20
